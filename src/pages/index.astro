    <!-- Client-side Interactive Application Logic -->
    <script>
      // State variables
      let uploadedFile = null;
      let currentAnalysisResult = null;
      let testHistory = [];
      let videoStream = null;
      let configData = null;

      // DOM Elements
      const themeToggleBtn = document.getElementById("theme-toggle");
      const themeLightIcon = document.getElementById("theme-light-icon");
      const themeDarkIcon = document.getElementById("theme-dark-icon");

      const dropZone = document.getElementById("drop-zone");
      const fileInput = document.getElementById("file-input");
      const viewerContainer = document.getElementById("viewer-container");
      const imageCanvas = document.getElementById("image-canvas");
      const btnResetImage = document.getElementById("btn-reset-image");
      const resultPanel = document.getElementById("result-panel");

      const btnUseCamera = document.getElementById("btn-use-camera");
      const cameraBtnContainer = document.getElementById(
        "camera-btn-container",
      );
      const cameraContainer = document.getElementById("camera-container");
      const cameraVideo = document.getElementById("camera-video");
      const btnCapture = document.getElementById("btn-capture");
      const btnCancelCamera = document.getElementById("btn-cancel-camera");

      const phVal = document.getElementById("ph-val");
      const phGauge = document.getElementById("ph-gauge");
      const classBadge = document.getElementById("class-badge");
      const resultDesc = document.getElementById("result-desc");
      const swatchSampled = document.getElementById("swatch-sampled");
      const swatchMatched = document.getElementById("swatch-matched");
      const saveTestForm = document.getElementById("save-test-form");
      const testTagInput = document.getElementById("test-tag");

      const historyEmpty = document.getElementById("history-empty");
      const historyList = document.getElementById("history-list");
      const testsCountText = document.getElementById("tests-count");
      const graphContainer = document.getElementById("graph-container");
      const guideScale = document.getElementById("guide-scale");

      // Initialize
      document.addEventListener("DOMContentLoaded", () => {
        initTheme();
        loadHistory();
        fetchConfig();
      });

      // --- Theme Handling ---
      function initTheme() {
        const savedTheme =
          localStorage.getItem("theme") ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");
        setTheme(savedTheme);

        themeToggleBtn.addEventListener("click", () => {
          const currentTheme = document.documentElement.classList.contains(
            "dark",
          )
            ? "dark"
            : "light";
          setTheme(currentTheme === "dark" ? "light" : "dark");
        });
      }

      function setTheme(theme) {
        if (theme === "dark") {
          document.documentElement.classList.add("dark");
          themeLightIcon.style.display = "block";
          themeDarkIcon.style.display = "none";
        } else {
          document.documentElement.classList.remove("dark");
          themeLightIcon.style.display = "none";
          themeDarkIcon.style.display = "block";
        }
        localStorage.setItem("theme", theme);
      }

      // --- Config Fetching & Scale UI ---
      async function fetchConfig() {
        try {
          const res = await fetch("/api/config");
          if (res.ok) {
            configData = await res.json();
            renderScaleGuide(configData.reference_scale);
          }
        } catch (err) {
          console.error("Could not fetch calibration scale details", err);
        }
      }

      function renderScaleGuide(scale) {
        if (!scale || scale.length === 0) return;
        guideScale.innerHTML = "";
        scale.forEach((item) => {
          const step = document.createElement("div");
          step.className = "guide-scale-step";
          step.style.backgroundColor = item.color_hex;
          step.style.width = `${100 / scale.length}%`;
          step.setAttribute("data-ph", `pH ${item.ph}: ${item.description}`);
          guideScale.appendChild(step);
        });
      }

      // --- Image Upload / Canvas Handlers ---
      dropZone.addEventListener("click", () => fileInput.click());

      fileInput.addEventListener("change", (e) => {
        if (e.target.files.length > 0) {
          handleImageFile(e.target.files[0]);
        }
      });

      dropZone.addEventListener("dragover", (e) => {
        e.preventDefault();
        dropZone.style.borderColor = "var(--primary)";
      });

      dropZone.addEventListener("dragleave", () => {
        dropZone.style.borderColor = "var(--card-border)";
      });

      dropZone.addEventListener("drop", (e) => {
        e.preventDefault();
        dropZone.style.borderColor = "var(--card-border)";
        if (e.dataTransfer.files.length > 0) {
          handleImageFile(e.dataTransfer.files[0]);
        }
      });

      function handleImageFile(file) {
        uploadedFile = file;
        const reader = new FileReader();
        reader.onload = (event) => {
          const img = new Image();
          img.onload = () => {
            setupCanvas(img);
          };
          img.src = event.target.result;
        };
        reader.readAsDataURL(file);
      }

      function setupCanvas(img) {
        dropZone.style.display = "none";
        cameraBtnContainer.style.display = "none";
        viewerContainer.style.display = "flex";
        resultPanel.style.display = "none";

        const ctx = imageCanvas.getContext("2d");

        // Define clean display constraints
        const maxCanvasWidth = 600;
        const scale = Math.min(1, maxCanvasWidth / img.width);
        imageCanvas.width = img.width * scale;
        imageCanvas.height = img.height * scale;

        ctx.drawImage(img, 0, 0, imageCanvas.width, imageCanvas.height);

        // Retain original reference sizes for correct API calculation
        imageCanvas.setAttribute("data-orig-width", img.width.toString());
        imageCanvas.setAttribute("data-orig-height", img.height.toString());
      }

      // Pixel Interaction Handler
      imageCanvas.addEventListener("click", async (e) => {
        if (!uploadedFile) return;

        const rect = imageCanvas.getBoundingClientRect();

        // Current display dimension
        const displayedWidth = rect.width;
        const displayedHeight = rect.height;

        // Coordinate calculation inside canvas relative to the original image dimensions
        const origWidth = parseFloat(
          imageCanvas.getAttribute("data-orig-width"),
        );
        const origHeight = parseFloat(
          imageCanvas.getAttribute("data-orig-height"),
        );

        const scaleX = origWidth / displayedWidth;
        const scaleY = origHeight / displayedHeight;

        const clickX = Math.round((e.clientX - rect.left) * scaleX);
        const clickY = Math.round((e.clientY - rect.top) * scaleY);

        // Render a visual indicator crosshair on display
        redrawCanvasWithCrosshair(e.clientX - rect.left, e.clientY - rect.top);

        // Submit details to FastAPI endpoint
        await analyzePH(clickX, clickY);
      });

      function redrawCanvasWithCrosshair(x, y) {
        const ctx = imageCanvas.getContext("2d");
        // Clear and draw image from scratch
        const img = new Image();
        const reader = new FileReader();
        reader.onload = (event) => {
          img.onload = () => {
            ctx.drawImage(img, 0, 0, imageCanvas.width, imageCanvas.height);

            // Draw crosshair selector circle
            ctx.beginPath();
            ctx.arc(x, y, 10, 0, 2 * Math.PI);
            ctx.strokeStyle = "#ffffff";
            ctx.lineWidth = 3;
            ctx.stroke();

            ctx.beginPath();
            ctx.arc(x, y, 10, 0, 2 * Math.PI);
            ctx.strokeStyle = "var(--primary)";
            ctx.lineWidth = 1.5;
            ctx.stroke();

            ctx.beginPath();
            ctx.arc(x, y, 2, 0, 2 * Math.PI);
            ctx.fillStyle = "#ffffff";
            ctx.fill();
          };
          img.src = event.target.result;
        };
        reader.readAsDataURL(uploadedFile);
      }

      btnResetImage.addEventListener("click", () => {
        uploadedFile = null;
        currentAnalysisResult = null;
        dropZone.style.display = "block";
        cameraBtnContainer.style.display = "flex";
        viewerContainer.style.display = "none";
        resultPanel.style.display = "none";
        fileInput.value = "";
      });

      // --- Camera Handlers ---
      btnUseCamera.addEventListener("click", async () => {
        try {
          videoStream = await navigator.mediaDevices.getUserMedia({
            video: { facingMode: "environment" },
          });
          cameraVideo.srcObject = videoStream;
          cameraContainer.style.display = "block";
          dropZone.style.display = "none";
          cameraBtnContainer.style.display = "none";
        } catch (err) {
          alert("Could not access camera: " + err.message);
        }
      });

      btnCancelCamera.addEventListener("click", () => {
        stopCamera();
      });

      function stopCamera() {
        if (videoStream) {
          videoStream.getTracks().forEach((track) => track.stop());
          videoStream = null;
        }
        cameraContainer.style.display = "none";
        dropZone.style.display = "block";
        cameraBtnContainer.style.display = "flex";
      }

      btnCapture.addEventListener("click", () => {
        if (!videoStream) return;

        // Grab current frame onto a virtual canvas
        const tempCanvas = document.createElement("canvas");
        tempCanvas.width = cameraVideo.videoWidth;
        tempCanvas.height = cameraVideo.videoHeight;
        const tempCtx = tempCanvas.getContext("2d");
        tempCtx.drawImage(
          cameraVideo,
          0,
          0,
          tempCanvas.width,
          tempCanvas.height,
        );

        // Convert to Blob and handle
        tempCanvas.toBlob((blob) => {
          const file = new File([blob], "camera_capture.jpg", {
            type: "image/jpeg",
          });
          handleImageFile(file);
          stopCamera();
        }, "image/jpeg");
      });

      // --- Backend Analysis API Call ---
      async function analyzePH(x, y) {
        if (!uploadedFile) return;

        const formData = new FormData();
        formData.append("x", x);
        formData.append("y", y);
        formData.append("file", uploadedFile);

        try {
          phVal.innerText = "...";
          resultPanel.style.display = "block";

          const res = await fetch("/api/analyze", {
            method: "POST",
            body: formData,
          });

          if (!res.ok) {
            const errData = await res.json();
            throw new Error(errData.detail || "Analysis request failed.");
          }

          const data = await res.json();
          currentAnalysisResult = data;
          displayResult(data);
        } catch (err) {
          alert("Error: " + err.message);
          phVal.innerText = "-";
          resultPanel.style.display = "none";
        }
      }

      function displayResult(res) {
        phVal.innerText = res.estimated_ph.toFixed(1);

        // Dynamic Gauge Background color based on standard scales
        let gaugeColor = "var(--primary)";
        if (res.estimated_ph < 6.5) {
          gaugeColor = "var(--ph-acid)";
        } else if (res.estimated_ph > 7.5) {
          gaugeColor = "var(--ph-alkaline)";
        } else {
          gaugeColor = "var(--ph-neutral)";
        }
        phGauge.style.backgroundColor = gaugeColor;

        // Swatches
        swatchSampled.style.backgroundColor = res.sampled_hex;
        swatchMatched.style.backgroundColor = res.matched_hex;

        // Label Text
        classBadge.innerText = res.classification;
        classBadge.style.backgroundColor = gaugeColor + "1a"; // 10% opacity
        classBadge.style.color = gaugeColor;
        classBadge.style.border = `1px solid ${gaugeColor}4d`; // 30% opacity

        resultDesc.innerHTML = `This sample matches the <strong>${res.description}</strong> range of the Red Cabbage color scale calibration. Exact hex match: <code>${res.matched_hex}</code>, Sampled: <code>${res.sampled_hex}</code>`;

        // Autofill input with simple placeholder
        testTagInput.value = "";
      }

      // --- Local Storage & Graphing ---
      function loadHistory() {
        const saved = localStorage.getItem("ph_test_history");
        if (saved) {
          try {
            testHistory = JSON.parse(saved);
          } catch (e) {
            testHistory = [];
          }
        }
        renderHistory();
      }

      function saveHistory() {
        localStorage.setItem("ph_test_history", JSON.stringify(testHistory));
        renderHistory();
      }

      saveTestForm.addEventListener("submit", (e) => {
        e.preventDefault();
        if (!currentAnalysisResult) return;

        const tagName = testTagInput.value.trim();
        if (!tagName) return;

        const newTest = {
          id: "test_" + Date.now(),
          name: tagName,
          ph: currentAnalysisResult.estimated_ph,
          classification: currentAnalysisResult.classification,
          sampled_hex: currentAnalysisResult.sampled_hex,
          matched_hex: currentAnalysisResult.matched_hex,
          date: new Date().toLocaleDateString(undefined, {
            month: "short",
            day: "numeric",
            hour: "2-digit",
            minute: "2-digit",
          }),
          timestamp: Date.now(),
        };

        testHistory.unshift(newTest);
        saveHistory();

        // Clear result preview panel
        uploadedFile = null;
        currentAnalysisResult = null;
        dropZone.style.display = "block";
        cameraBtnContainer.style.display = "flex";
        viewerContainer.style.display = "none";
        resultPanel.style.display = "none";
        fileInput.value = "";
      });

      function renderHistory() {
        testsCountText.innerText = `${testHistory.length} test${testHistory.length === 1 ? "" : "s"} recorded`;

        if (testHistory.length === 0) {
          historyEmpty.style.display = "flex";
          historyList.style.display = "none";
          graphContainer.style.display = "none";
          return;
        }

        historyEmpty.style.display = "none";
        historyList.style.display = "flex";

        // Graph rendering trigger
        if (testHistory.length >= 2) {
          graphContainer.style.display = "block";
          drawHistoryGraph();
        } else {
          graphContainer.style.display = "none";
        }

        historyList.innerHTML = "";
        testHistory.forEach((item) => {
          // Color badge based on acidity
          let badgeColor = "var(--primary)";
          if (item.ph < 6.5) {
            badgeColor = "var(--ph-acid)";
          } else if (item.ph > 7.5) {
            badgeColor = "var(--ph-alkaline)";
          } else {
            badgeColor = "var(--ph-neutral)";
          }

          const entry = document.createElement("div");
          entry.className = "history-item";
          entry.innerHTML = `
            <div style="display: flex; align-items: center; gap: 12px;">
              <div class="history-badge">${item.ph.toFixed(1)}</div>
              <div class="history-info">
                <h4>${escapeHTML(item.name)}</h4>
                <p>${item.date} • <span style="color: ${badgeColor}; font-weight:600">${item.classification}</span></p>
              </div>
            </div>
            <div class="history-right">
              <div class="swatch-circle" style="background-color: ${item.sampled_hex}" title="Sampled: ${item.sampled_hex}"></div>
              <button class="btn btn-delete" onmouseover="this.style.backgroundColor='rgb(251, 189, 189)'" onmouseout="this.style.backgroundColor='transparent'" data-id="${item.id}" aria-label="Delete entry">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="3 6 5 6 21 6"></polyline>
                  <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                </svg>
              </button>
            </div>
          `;

          // Wire up delete event listener
          entry.querySelector(".btn-delete").addEventListener("click", (e) => {
            const id = e.currentTarget.getAttribute("data-id");
            testHistory = testHistory.filter((h) => h.id !== id);
            saveHistory();
          });

          historyList.appendChild(entry);
        });
      }

      function escapeHTML(str) {
        return str.replace(
          /[&<>'"]/g,
          (tag) =>
            ({
              "&": "&amp;",
              "<": "&lt;",
              ">": "&gt;",
              "'": "&#39;",
              '"': "&quot;",
            })[tag] || tag,
        );
      }

      // --- SVG Line Graph Engine ---
      function drawHistoryGraph() {
        const svg = document.getElementById("chart-svg");
        const pathLine = svg.querySelector(".chart-line");
        const pathArea = svg.querySelector(".chart-area");
        const nodesGroup = document.getElementById("chart-nodes");
        const tooltip = document.getElementById("chart-tooltip");

        // Grab last 7 samples in chronological order
        const graphItems = [...testHistory].slice(0, 7).reverse();
        if (graphItems.length < 2) return;

        // Chart geometry inside 400x150 boundary box
        const width = 400;
        const height = 150;
        const paddingLeft = 30;
        const paddingRight = 20;
        const paddingTop = 20;
        const paddingBottom = 20;

        const chartWidth = width - paddingLeft - paddingRight;
        const chartHeight = height - paddingTop - paddingBottom;

        // Y-axis spans pH levels from 0 to 14
        const yMin = 0;
        const yMax = 14;

        // Generate coordinates
        const points = graphItems.map((item, index) => {
          const x =
            paddingLeft + (index / (graphItems.length - 1)) * chartWidth;
          // Scale pH value inverse on Y axis (SVG coordinate y=0 is top)
          const y =
            paddingTop +
            chartHeight -
            ((item.ph - yMin) / (yMax - yMin)) * chartHeight;
          return { x, y, item };
        });

        // Compile SVG Path string
        let dLine = `M ${points[0].x} ${points[0].y}`;
        for (let i = 1; i < points.length; i++) {
          dLine += ` L ${points[i].x} ${points[i].y}`;
        }

        let dArea = `${dLine} L ${points[points.length - 1].x} ${paddingTop + chartHeight} L ${points[0].x} ${paddingTop + chartHeight} Z`;

        pathLine.setAttribute("d", dLine);
        pathArea.setAttribute("d", dArea);

        // Clear old dots and build interactive nodes
        nodesGroup.innerHTML = "";
        points.forEach((pt) => {
          const circle = document.createElementNS(
            "http://www.w3.org/2000/svg",
            "circle",
          );
          circle.setAttribute("cx", pt.x.toString());
          circle.setAttribute("cy", pt.y.toString());
          circle.setAttribute("r", "6");
          circle.setAttribute("class", "chart-dot");

          let color = "var(--primary)";
          if (pt.item.ph < 6.5) color = "var(--ph-acid)";
          else if (pt.item.ph > 7.5) color = "var(--ph-alkaline)";
          else color = "var(--ph-neutral)";
          circle.style.stroke = color;

          // Tooltip hover actions
          circle.addEventListener("mouseover", (e) => {
            tooltip.style.opacity = "1";
            tooltip.innerHTML = `<strong>${escapeHTML(pt.item.name)}</strong><br/>pH: ${pt.item.ph.toFixed(1)} (${pt.item.classification})`;

            const rect = svg.getBoundingClientRect();
            // Offset positioning
            tooltip.style.left = `${(pt.x / width) * rect.width - 40}px`;
            tooltip.style.top = `${(pt.y / height) * rect.height - 50}px`;
          });

          circle.addEventListener("mouseout", () => {
            tooltip.style.opacity = "0";
          });

          nodesGroup.appendChild(circle);
        });
      }
    </script>
  </body>
</html>
