---
import "../styles/global.css";
import GitHub from "../icons/gitHub.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>pH Detection | Water Quality Analysis</title>
    <meta
      name="description"
      content="Instant pH detection of liquids using AI-powered image recognition of red cabbage indicators. Upload or capture photos and track pH levels over time."
    />

    <style>
      /* Page specific styles */
      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 0;
        margin-bottom: 40px;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        font-family: var(--font-display);
        font-weight: 800;
        font-size: 20px;
        color: var(--text-primary);
        text-decoration: none;
      }

      .logo-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: var(--radius-sm);
        background: var(--primary-light);
        color: var(--primary);
      }

      .logo-text span {
        display: block;
        font-size: 11px;
        font-weight: 500;
        color: var(--text-tertiary);
        margin-top: -4px;
      }

      nav {
        display: flex;
        gap: 32px;
      }

      nav a {
        color: var(--text-secondary);
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        transition: color 0.2s ease;
      }

      nav a:hover {
        color: var(--primary);
      }

      .header-actions {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .theme-toggle {
        background: none;
        border: none;
        cursor: pointer;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-secondary);
        transition: background-color 0.2s ease;
      }

      .theme-toggle:hover {
        background-color: var(--bg-secondary);
        color: var(--text-primary);
      }

      /* Hero Section */
      .hero {
        text-align: center;
        max-width: 800px;
        margin: 0 auto 60px;
        animation: fadeIn 0.5s ease-out forwards;
      }

      .hero-badge {
        margin-bottom: 20px;
      }

      .hero h1 {
        font-size: 52px;
        font-weight: 800;
        letter-spacing: -0.03em;
        margin-bottom: 24px;
        background: linear-gradient(
          135deg,
          var(--text-primary) 30%,
          var(--primary) 90%
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .hero p {
        font-size: 18px;
        color: var(--text-secondary);
        margin-bottom: 32px;
        line-height: 1.6;
      }

      .metrics {
        display: flex;
        justify-content: center;
        gap: 60px;
        margin-top: 40px;
      }

      .metric-item {
        text-align: center;
      }

      .metric-value {
        font-family: var(--font-display);
        font-size: 32px;
        font-weight: 800;
        color: var(--text-primary);
        line-height: 1;
      }

      .metric-label {
        font-size: 12px;
        color: var(--text-tertiary);
        font-weight: 600;
        text-transform: uppercase;
        margin-top: 4px;
      }

      /* Dashboard Layout */
      .dashboard {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 32px;
        margin-bottom: 80px;
      }

      @media (max-width: 900px) {
        .dashboard {
          grid-template-columns: 1fr;
        }
      }

      .card-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--card-border);
      }

      .card-header h2 {
        font-size: 20px;
        font-weight: 700;
      }

      .card-header p {
        font-size: 13px;
        color: var(--text-secondary);
      }

      .card-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background-color: var(--bg-secondary);
        color: var(--text-secondary);
      }

      .dashboard-card {
        padding: 32px;
        height: fit-content;
      }

      /* File upload / canvas region */
      .upload-zone {
        border: 2px dashed var(--card-border);
        border-radius: var(--radius-md);
        padding: 48px 24px;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s ease;
        background-color: rgba(243, 246, 250, 0.3);
      }

      .upload-zone:hover {
        border-color: var(--primary);
        background-color: var(--primary-light);
      }

      .upload-icon {
        font-size: 40px;
        color: var(--text-tertiary);
        margin-bottom: 16px;
      }

      .upload-title {
        font-weight: 700;
        font-size: 16px;
        margin-bottom: 8px;
      }

      .upload-desc {
        font-size: 13px;
        color: var(--text-secondary);
        max-width: 320px;
        margin: 0 auto;
      }

      /* Camera controls */
      .camera-btn-container {
        margin-bottom: 20px;
        display: flex;
        justify-content: center;
      }

      .camera-container {
        position: relative;
        width: 100%;
        max-height: 400px;
        border-radius: var(--radius-md);
        overflow: hidden;
        margin-bottom: 20px;
        background: #000;
        display: none;
      }

      .camera-video {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .camera-overlay {
        position: absolute;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 12px;
      }

      /* Active Canvas Viewer */
      .viewer-container {
        display: none;
        flex-direction: column;
        align-items: center;
      }

      .canvas-wrapper {
        position: relative;
        max-width: 100%;
        border-radius: var(--radius-md);
        overflow: hidden;
        box-shadow: var(--shadow-lg);
        cursor: crosshair;
        background-color: #000;
      }

      .canvas-wrapper canvas {
        display: block;
        max-width: 100%;
        height: auto;
      }

      .canvas-instructions {
        margin-top: 16px;
        font-size: 14px;
        font-weight: 600;
        color: var(--primary);
        display: flex;
        align-items: center;
        gap: 8px;
      }

      /* Result Display Styling */
      .result-panel {
        display: none;
        margin-top: 32px;
        padding-top: 24px;
        border-top: 1px solid var(--card-border);
        width: 100%;
        animation: fadeIn 0.3s ease-out;
      }

      .result-title {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 16px;
      }

      .result-flex {
        display: flex;
        gap: 32px;
        align-items: center;
      }

      @media (max-width: 580px) {
        .result-flex {
          flex-direction: column;
          align-items: flex-start;
          gap: 20px;
        }
      }

      .ph-gauge {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #fff;
        box-shadow: var(--shadow-lg);
        position: relative;
      }

      .ph-gauge-value {
        font-family: var(--font-display);
        font-size: 40px;
        font-weight: 800;
        line-height: 1;
      }

      .ph-gauge-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        opacity: 0.8;
      }

      .result-details {
        flex: 1;
      }

      .classification-badge {
        display: inline-flex;
        font-weight: 700;
        font-size: 13px;
        padding: 4px 12px;
        border-radius: 9999px;
        margin-bottom: 12px;
      }

      .color-comparison {
        display: flex;
        gap: 16px;
        margin: 12px 0;
      }

      .comparison-swatch {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        font-weight: 600;
      }

      .swatch-circle {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        border: 1px solid var(--card-border);
      }

      /* Log list and graph inside Recent Tests */
      .history-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 48px 16px;
        text-align: center;
        color: var(--text-tertiary);
      }

      .history-empty-icon {
        font-size: 32px;
        margin-bottom: 12px;
      }

      .history-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        max-height: 400px;
        overflow-y: auto;
        padding-right: 4px;
      }

      .history-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px;
        border-radius: var(--radius-md);
        background-color: var(--bg-secondary);
        border: 1px solid var(--card-border);
        transition: transform 0.2s ease;
      }

      .history-item:hover {
        transform: translateX(2px);
      }

      .history-info h4 {
        font-size: 14px;
        font-weight: 700;
      }

      .history-info p {
        font-size: 11px;
        color: var(--text-tertiary);
      }

      .history-badge {
        font-family: var(--font-display);
        font-size: 14px;
        font-weight: 800;
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
      }

      .history-right {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .btn-delete {
        background: none;
        border: none;
        color: transparent;
        cursor: pointer;
        padding: 4px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .btn-delete:hover {
        color: var(--ph-acid);
        background-color: rgb(251, 189, 189) !important;
      }

      .graph-container {
        margin-bottom: 24px;
        display: none;
        padding: 16px 12px;
        border-radius: var(--radius-md);
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.02) 0%,
          rgba(37, 99, 235, 0.01) 100%
        );
        border: 1px dashed var(--card-border);
      }

      /* Input form for saving test */
      .save-test-form {
        margin-top: 16px;
        display: flex;
        gap: 12px;
      }

      .save-test-form input {
        flex: 1;
        background: var(--bg-secondary);
        border: 1px solid var(--card-border);
        padding: 8px 16px;
        border-radius: 9999px;
        color: var(--text-primary);
        font-family: var(--font-sans);
        font-size: 14px;
        outline: none;
      }

      .save-test-form input:focus {
        border-color: var(--primary);
      }

      /* Tips list container */
      .tips-container {
        margin-top: 24px;
        padding: 24px;
        border-radius: var(--radius-md);
        background-color: var(--primary-light);
        border: 1px solid rgba(37, 99, 235, 0.1);
      }

      .tips-container h3 {
        font-size: 15px;
        font-weight: 700;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--primary);
      }

      .tips-list {
        list-style-type: none;
        padding-left: 0;
      }

      .tips-list li {
        font-size: 13px;
        color: var(--text-secondary);
        position: relative;
        padding-left: 20px;
        margin-bottom: 8px;
      }

      .tips-list li::before {
        content: "•";
        position: absolute;
        left: 6px;
        color: var(--primary);
        font-weight: bold;
      }

      /* Features grid */
      .why-section {
        margin-bottom: 80px;
      }

      .why-header {
        text-align: center;
        max-width: 600px;
        margin: 0 auto 40px;
      }

      .why-header h2 {
        font-size: 32px;
        margin-bottom: 12px;
      }

      .why-header p {
        color: var(--text-secondary);
        font-size: 15px;
      }

      .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }

      @media (max-width: 768px) {
        .features-grid {
          grid-template-columns: 1fr;
        }
      }

      .feature-card {
        padding: 24px;
        border-radius: var(--radius-md);
        border: 1px solid var(--card-border);
        background-color: var(--card-bg);
      }

      .feature-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border-radius: var(--radius-sm);
        background-color: var(--bg-secondary);
        color: var(--text-primary);
        font-size: 20px;
        margin-bottom: 16px;
      }

      .feature-card h3 {
        font-size: 18px;
        margin-bottom: 10px;
      }

      .feature-card p {
        font-size: 13px;
        color: var(--text-secondary);
      }

      /* Footer */
      footer {
        border-top: 1px solid var(--card-border);
        padding: 60px 0 24px;
        margin-top: 80px;
      }

      .footer-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr 1fr;
        gap: 40px;
        margin-bottom: 40px;
      }

      @media (max-width: 768px) {
        .footer-grid {
          grid-template-columns: 1fr;
          gap: 24px;
        }
      }

      .footer-brand p {
        font-size: 13px;
        color: var(--text-secondary);
        margin: 16px 0;
        max-width: 280px;
      }

      .footer-col h4 {
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 16px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .footer-col ul {
        list-style: none;
      }

      .footer-col ul li {
        margin-bottom: 8px;
      }

      .footer-col ul li a {
        color: var(--text-secondary);
        font-size: 13px;
        text-decoration: none;
        transition: color 0.2s ease;
      }

      .footer-col ul li a:hover {
        color: var(--primary);
      }

      .social-links {
        display: flex;
        gap: 12px;
      }

      .social-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background-color: var(--bg-secondary);
        color: var(--text-secondary);
        text-decoration: none;
        transition: all 0.2s ease;
      }

      .social-icon:hover {
        background-color: var(--text-primary);
        color: var(--bg-primary);
      }

      .sub-footer {
        border-top: 1px solid var(--card-border);
        padding-top: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 12px;
        color: var(--text-tertiary);
      }

      .sub-footer-links {
        display: flex;
        gap: 24px;
      }

      .sub-footer-links a {
        color: var(--text-tertiary);
        text-decoration: none;
      }

      .sub-footer-links a:hover {
        color: var(--primary);
      }

      /* Guide scale UI */
      .guide-scale {
        display: flex;
        height: 20px;
        border-radius: 10px;
        overflow: hidden;
        margin: 16px 0;
        border: 1px solid var(--card-border);
      }

      .guide-scale-step {
        flex: 1;
        height: 100%;
        position: relative;
        cursor: pointer;
      }

      .guide-scale-step:hover::after {
        content: attr(data-ph);
        position: absolute;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--text-primary);
        color: var(--bg-primary);
        font-size: 10px;
        font-weight: 700;
        padding: 2px 6px;
        border-radius: 4px;
        pointer-events: none;
      }
    </style>
  </head>
  <body>
    <!-- Main Content Container -->
    <div class="container animate-fade-in">
      <!-- HEADER -->
      <header>
        <a href="#" class="logo">
          <div class="logo-icon">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M12 22a7 7 0 0 0 7-7c0-4.3-7-11-7-11S5 10.7 5 15a7 7 0 0 0 7 7z"
              ></path>
            </svg>
          </div>
          <div class="logo-text">
            pH Detection
            <span>Water Quality Analysis</span>
          </div>
        </a>

        <nav>
          <a href="#how-it-works">How It Works</a>
          <a href="#guide">pH Guide</a>
          <a href="#footer">About</a>
        </nav>

        <div class="header-actions">
          <button
            id="theme-toggle"
            class="theme-toggle"
            aria-label="Toggle dark mode"
          >
            <!-- Light mode icon -->
            <svg
              id="theme-light-icon"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              style="display: none;"
            >
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <!-- Dark mode icon -->
            <svg
              id="theme-dark-icon"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>

          <a href="#analyzer-section" class="btn btn-primary">Get Started</a>
        </div>
      </header>

      <!-- HERO SECTION -->
      <section class="hero">
        <div class="hero-badge">
          <span class="badge badge-ai">
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              style="margin-right: 4px;"
            >
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
              ></path>
            </svg>
            AI-Powered Water Analysis
          </span>
        </div>
        <h1>Instant pH Detection for<br />Clean Water</h1>
        <p>
          Upload or capture an image of your pH test solution using red cabbage
          indicator and get accurate results instantly. Track your water quality
          over time with our smart tagging system.
        </p>

        <div class="metrics">
          <div class="metric-item">
            <div class="metric-value">99%</div>
            <div class="metric-label">Accuracy</div>
          </div>
          <div class="metric-item">
            <div class="metric-value">2s</div>
            <div class="metric-label">Analysis Time</div>
          </div>
          <div class="metric-item">
            <div class="metric-value">Free</div>
            <div class="metric-label">Forever</div>
          </div>
        </div>
      </section>

      <!-- MAIN DASHBOARD -->
      <section id="analyzer-section" class="dashboard">
        <!-- Left: Upload & Analyze -->
        <div class="glass-card dashboard-card">
          <div class="card-header">
            <div class="card-icon">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"
                ></path>
              </svg>
            </div>
            <div>
              <h2>Analyze pH Level</h2>
              <p>Upload or capture a pH test image</p>
            </div>
          </div>

          <!-- Camera video container -->
          <div class="camera-container" id="camera-container">
            <video class="camera-video" id="camera-video" autoplay playsinline
            ></video>
            <div class="camera-overlay">
              <button class="btn btn-primary" id="btn-capture"
                >Capture Photo</button
              >
              <button class="btn btn-secondary" id="btn-cancel-camera"
                >Cancel</button
              >
            </div>
          </div>

          <div class="camera-btn-container" id="camera-btn-container">
            <button class="btn btn-secondary" id="btn-use-camera">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                style="margin-right: 4px;"
              >
                <path
                  d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"
                ></path>
                <circle cx="12" cy="13" r="4"></circle>
              </svg>
              Use Camera
            </button>
          </div>

          <!-- Upload dropzone -->
          <div class="upload-zone" id="drop-zone">
            <div class="upload-icon">
              <svg
                width="48"
                height="48"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path d="M12 5v14M5 12h14" stroke-linecap="round"></path>
              </svg>
            </div>
            <div class="upload-title">Upload pH Test Image</div>
            <div class="upload-desc">
              Drag & drop your pH test image here, or click to browse. Works
              best with Red Cabbage indicator solutions.
            </div>
            <input
              type="file"
              id="file-input"
              accept="image/*"
              style="display: none;"
            />
          </div>

          <!-- Active image viewer -->
          <div class="viewer-container" id="viewer-container">
            <div class="canvas-wrapper">
              <canvas id="image-canvas"></canvas>
            </div>
            <div class="canvas-instructions">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
